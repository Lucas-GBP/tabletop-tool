{
  "name": "tabletop-tool",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "engines": {
    "node": "26.1.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext .ts,.tsx && cd src-tauri && cargo clippy -- -D warnings",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:ts": "eslint . --ext .ts,.tsx",
    "lint:rs": "cd src-tauri && cargo clippy -- -D warnings",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" && cd src-tauri && cargo fmt",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" && cd src-tauri && cargo fmt -- --check",
    "format:check:ts": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format:check:rs": "cd src-tauri && cargo fmt -- --check",
    "check": "npm run lint && npm run format:check",
    "fix": "npm run lint:fix && npm run format"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.8.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
