{
  "name": "tabletop-tool",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "npm run lint && npm run lint:rust",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" && cd src-tauri && cargo fmt",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" && cd src-tauri && cargo fmt -- --check",
    "format:frontend": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:rust": "cd src-tauri && cargo fmt"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
